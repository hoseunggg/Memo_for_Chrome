{
  "manifest_version": 3,
  "name": "Memo for Chrome",
  "description": "A simple Chrome notepad with Google Drive sync.",
  "version": "0.1.0",
  "action": {
    "default_title": "Memo for Chrome",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "memo.html",
  "permissions": [
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "811344902051-ddrjk9pcc9ajoe3fgn52j7rfejgnj2jj.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive"
    ]
  },
  "background": {
    "service_worker": "js/background.js"
  }
}
